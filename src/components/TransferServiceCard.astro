---
export interface Props {
  image: string;
  title: string;
  body: string;
  href: string;
  ctaLabel: string;
  imageAlt?: string;
}

const { image, title, body, href, ctaLabel, imageAlt = '' } = Astro.props;
---
<a href={href} class="transfer-card group">
  <div class="transfer-card-media">
    <img src={image} alt={imageAlt || title} loading="lazy" decoding="async" class="transfer-card-img" />
  </div>

  <div class="transfer-card-body">
    <h3 class="transfer-card-title">{title}</h3>
    <p class="transfer-card-summary">{body}</p>
    <span class="transfer-card-cta">{ctaLabel}<span aria-hidden="true">→</span></span>
  </div>
</a>

<style>
  .transfer-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: var(--radius-card);
    background: var(--color-charcoal);
    box-shadow: var(--shadow-card);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
  }

  .transfer-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card-hover);
  }

  .transfer-card-media {
    position: relative;
    aspect-ratio: 16 / 11;
    overflow: hidden;
  }

  .transfer-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .transfer-card:hover .transfer-card-img {
    transform: scale(1.06);
  }

  .transfer-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.75rem;
    color: #ffffff;
  }

  @media (min-width: 768px) {
    .transfer-card-body {
      padding: 2rem;
    }
  }

  .transfer-card-title {
    font-size: clamp(1.375rem, 2.2vw, 1.75rem);
    line-height: 1.2;
    color: #ffffff;
  }

  .transfer-card-summary {
    margin-top: 1.1rem;
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.66);
  }

  .transfer-card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    margin-top: 1.75rem;
    padding: 0.95rem 1.5rem;
    border-radius: var(--radius-pill);
    background: var(--color-gold);
    color: var(--color-ink);
    font-size: 0.95rem;
    font-weight: 600;
    transition: box-shadow 0.3s ease, transform 0.25s ease;
  }

  .transfer-card-cta span {
    transition: transform 0.25s ease;
  }

  .transfer-card:hover .transfer-card-cta {
    box-shadow: var(--shadow-gold-halo);
  }

  .transfer-card:hover .transfer-card-cta span {
    transform: translateX(3px);
  }
</style>
