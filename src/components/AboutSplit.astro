---
export interface Props {
  heading: string;
  paragraphs: string[];
  image: string;
  imageAlt?: string;
}
const { heading, paragraphs, image, imageAlt = '' } = Astro.props;
---
<section class="about-split">
  <div class="about-split-text">
    <div class="about-split-text-inner">
      <h1 class="about-split-heading">{heading}</h1>
      <div class="about-split-body">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </div>
  <div class="about-split-media">
    <img src={image} alt={imageAlt || heading} loading="lazy" decoding="async" />
  </div>
</section>

<style>
  .about-split {
    display: grid;
    grid-template-columns: 1fr;
    overflow-x: clip;
  }

  @media (min-width: 1024px) {
    .about-split {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }
  }

  .about-split-text {
    min-width: 0;
    display: flex;
    justify-content: flex-start;
    padding: clamp(7rem, 22vw, 8rem) clamp(1.25rem, 5vw, 3.5rem) clamp(3rem, 7vw, 6rem);
    background: #ffffff;
  }

  @media (min-width: 1024px) {
    .about-split-text {
      justify-content: flex-end;
      padding-top: clamp(6rem, 9vw, 8rem);
    }
  }

  .about-split-text-inner {
    width: 100%;
    max-width: 36rem;
  }

  .about-split-heading {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .about-split-body {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-split-body p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-ink);
  }

  .about-split-media {
    position: relative;
    min-width: 0;
    min-height: 18rem;
  }

  .about-split-media img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1023px) {
    .about-split-media {
      aspect-ratio: 16 / 10;
    }
  }
</style>
