---
export interface Props {
  href: string;
  image: string;
  title: string;
  body: string;
  priceLabel: string;
  ctaLabel: string;
  imageAlt?: string;
}
const { href, image, title, body, priceLabel, ctaLabel, imageAlt } = Astro.props;
---
<a
  href={href}
  class="group relative flex min-h-[420px] flex-col justify-end overflow-hidden rounded-card border border-warm-border bg-charcoal shadow-card transition-all duration-500 hover:-translate-y-1 hover:shadow-card-hover"
>
  <img
    src={image}
    alt={imageAlt || `${title} in Santorini with Santorini Imperial`}
    loading="lazy"
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/45 to-black/15"></div>
  <div class="relative p-8 text-white">
    <h3 class="font-display text-3xl font-bold leading-tight">{title}</h3>
    <p class="mt-3 max-w-sm text-sm leading-relaxed text-white/80">{body}</p>
    <div class="mt-6 flex items-end justify-between gap-4 border-t border-white/15 pt-5">
      <span class="text-sm font-medium text-white">{priceLabel}</span>
      <span class="text-sm font-semibold text-white transition-transform duration-300 group-hover:translate-x-1">
        {ctaLabel} →
      </span>
    </div>
  </div>
</a>
