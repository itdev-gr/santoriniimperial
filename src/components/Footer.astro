---
import { createT, localePath, bundleForLocale, type Locale } from '../lib/i18n';

export interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
const t = createT(locale);
const lp = (p: string) => localePath(locale, p);
const year = new Date().getFullYear();
const bundle = bundleForLocale(locale) as {
  footer: {
    services: string;
    airport: string;
    port: string;
    tours: string;
    fleet: string;
    tours_heading: string;
    company: string;
    contact: string;
    location: string;
    open: string;
    copyright: string;
    powered: string;
    tour_links: { slug: string; label: string }[];
  };
};

const tourLinks = bundle.footer.tour_links.map((tl) => ({
  href: lp(`/tours/${tl.slug}/`),
  label: tl.label,
}));
---
<footer class="site-footer bg-black text-white">
  <div class="footer-shell w-full px-5 sm:px-8 lg:px-12 xl:px-16 2xl:px-20">
    <div class="footer-grid py-16 lg:py-20 xl:py-24">
      <div class="footer-brand">
        <a href={lp('/')} aria-label="Santorini Imperial — Home">
          <img
            src="/images/logo/si-logo.svg"
            alt="Santorini Imperial — Travel & Tours"
            class="h-36 w-auto sm:h-40 lg:h-44"
            width="252"
            height="252"
          />
        </a>
      </div>

      <div class="footer-col">
        <h2 class="footer-heading">{bundle.footer.services}</h2>
        <ul class="footer-links">
          <li><a href={lp('/transfers/')}>{bundle.footer.airport}</a></li>
          <li><a href={lp('/transfers/')}>{bundle.footer.port}</a></li>
          <li><a href={lp('/tours/')}>{bundle.footer.tours}</a></li>
          <li><a href={lp('/fleet/')}>{bundle.footer.fleet}</a></li>
          <li><a href={lp('/book/')}>{t('nav.book')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h2 class="footer-heading">{bundle.footer.tours_heading}</h2>
        <ul class="footer-links">
          {tourLinks.map(tl => (
            <li><a href={tl.href}>{tl.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h2 class="footer-heading">{bundle.footer.company}</h2>
        <ul class="footer-links">
          <li><a href={lp('/about/')}>{t('nav.about')}</a></li>
          <li><a href={lp('/gallery/')}>{t('nav.gallery')}</a></li>
          <li><a href={lp('/blog/')}>{t('nav.blog')}</a></li>
          <li><a href={lp('/contact/')}>{bundle.footer.contact}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h2 class="footer-heading">{bundle.footer.contact}</h2>
        <ul class="footer-links">
          <li>
            <a href="https://www.google.com/maps?cid=10485640130576047174" target="_blank" rel="noopener">
              {bundle.footer.location}
            </a>
          </li>
          <li><a href="tel:+306940355016">+30 6940 355016</a></li>
          <li class="footer-muted">WhatsApp · Viber · WeChat</li>
          <li><a href="mailto:imperialsantorini@gmail.com">imperialsantorini@gmail.com</a></li>
          <li class="footer-muted">{bundle.footer.open}</li>
        </ul>
        <div class="footer-social">
          <a
            href="https://instagram.com/santorini_imperial"
            target="_blank"
            rel="noopener"
            aria-label="Instagram — @santorini_imperial"
            class="footer-social-link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a
            href="https://wa.me/306940355016"
            target="_blank"
            rel="noopener"
            aria-label="WhatsApp — +30 6940 355016"
            class="footer-social-link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.83 9.83 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.82 11.82 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bar border-t border-white/12">
    <div class="footer-shell w-full px-5 sm:px-8 lg:px-12 xl:px-16 2xl:px-20 py-6 lg:py-7">
      <div class="footer-bar-inner">
        <p class="footer-copyright">© {year} Santorini Imperial. {bundle.footer.copyright}</p>
        <p class="footer-powered">
          {bundle.footer.powered}
          <a href="https://www.itdev.gr" target="_blank" rel="noopener">IT DEV</a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    gap: 2.5rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.75rem 2rem;
      text-align: left;
    }

    .footer-brand {
      grid-column: 1 / -1;
      display: flex;
      justify-content: center;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: minmax(220px, 1.15fr) repeat(4, minmax(0, 1fr));
      gap: 3rem 2.5rem;
      align-items: start;
    }

    .footer-brand {
      grid-column: auto;
      justify-content: flex-start;
    }
  }

  @media (min-width: 1280px) {
    .footer-grid {
      gap: 3.5rem 4rem;
    }
  }

  .footer-brand a {
    display: inline-block;
    line-height: 0;
    text-decoration: none;
  }

  .footer-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ffffff;
  }

  @media (min-width: 1024px) {
    .footer-heading {
      font-size: 0.875rem;
      letter-spacing: 0.2em;
    }
  }

  .footer-links {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    font-size: 1rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.92);
  }

  @media (min-width: 1024px) {
    .footer-links {
      margin-top: 1.5rem;
      gap: 0.95rem;
      font-size: 1.0625rem;
    }
  }

  .footer-links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-gold);
  }

  .footer-muted {
    color: rgba(255, 255, 255, 0.72);
  }

  .footer-social {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .footer-social {
      justify-content: flex-start;
    }
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 9999px;
    color: #ffffff;
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .footer-social-link:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background-color: rgba(255, 255, 255, 0.04);
  }

  .footer-copyright {
    color: #ffffff;
  }

  .footer-bar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.65);
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-bar-inner {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      font-size: 1rem;
    }

    .footer-copyright {
      grid-column: 1;
      justify-self: start;
      text-align: left;
    }

    .footer-powered {
      grid-column: 2;
      justify-self: center;
      text-align: center;
    }
  }

  .footer-bar-inner a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-bar-inner a:hover {
    color: var(--color-gold);
  }
</style>
