---
export interface Stat { value: string; label: string; }
export interface Props {
  image: string;
  imageAlt?: string;
  kicker: string;
  heading: string;
  body: string;
  ctaLabel: string;
  ctaHref: string;
  stats?: Stat[];
}
const { image, imageAlt = '', kicker, heading, body, ctaLabel, ctaHref, stats = [] } = Astro.props;
---
<section class="about-teaser">
  <div class="container-page about-grid">
    <div class="about-media">
      <div class="about-media-frame">
        <img src={image} alt={imageAlt} loading="lazy" decoding="async" />
      </div>
      <span class="about-media-accent" aria-hidden="true"></span>

      {stats.length > 0 && (
        <div class="about-badge">
          {stats.map((s) => (
            <div class="about-badge-item">
              <span class="about-badge-value">{s.value}</span>
              <span class="about-badge-label">{s.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="about-content">
      <div class="about-kicker">
        <span class="about-kicker-line" aria-hidden="true"></span>
        <span>{kicker}</span>
      </div>
      <h2 class="about-heading">{heading}</h2>
      <p class="about-body">{body}</p>
      <a href={ctaHref} class="about-cta">
        <span>{ctaLabel}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14" /><path d="M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .about-teaser {
    background: var(--color-warm);
    padding-block: var(--spacing-section);
    overflow: hidden;
  }

  .about-grid {
    display: grid;
    gap: 3.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .about-grid {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1fr);
      gap: 5.5rem;
    }
  }

  /* ---------- Media ---------- */
  .about-media {
    position: relative;
    isolation: isolate;
  }

  .about-media-frame {
    position: relative;
    z-index: 2;
    overflow: hidden;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card-hover);
  }

  .about-media-frame img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .about-media:hover .about-media-frame img {
    transform: scale(1.04);
  }

  .about-media-accent {
    position: absolute;
    z-index: 1;
    right: -1.25rem;
    bottom: -1.25rem;
    width: 58%;
    height: 70%;
    border: 1.5px solid var(--color-gold);
    border-radius: var(--radius-card);
    opacity: 0.55;
  }

  .about-badge {
    position: absolute;
    z-index: 3;
    left: 1.25rem;
    bottom: 1.25rem;
    display: flex;
    align-items: stretch;
    gap: 0.25rem;
    padding: 0.9rem 1.1rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border-radius: 14px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.14);
  }

  .about-badge-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-inline: 0.85rem;
    text-align: center;
  }

  .about-badge-item + .about-badge-item {
    border-left: 1px solid var(--color-warm-border);
  }

  .about-badge-value {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-ink);
  }

  .about-badge-label {
    font-size: 0.6875rem;
    line-height: 1.2;
    color: rgba(10, 10, 10, 0.55);
    max-width: 6.5rem;
  }

  @media (max-width: 420px) {
    .about-badge {
      left: 0.75rem;
      bottom: 0.75rem;
      padding: 0.7rem 0.5rem;
    }
    .about-badge-item { padding-inline: 0.55rem; }
    .about-badge-value { font-size: 1.05rem; }
    .about-badge-label { font-size: 0.625rem; }
  }

  /* ---------- Content ---------- */
  .about-kicker {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-size: var(--text-kicker);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .about-kicker-line {
    width: 2.5rem;
    height: 1px;
    background: var(--color-gold);
  }

  .about-heading {
    margin-top: 1.25rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
    color: var(--color-ink);
  }

  .about-body {
    margin-top: 1.5rem;
    max-width: 34rem;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(10, 10, 10, 0.64);
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 2.25rem;
    padding: 0.95rem 1.9rem;
    border-radius: var(--radius-pill);
    background: var(--color-ink);
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .about-cta svg {
    width: 1.05rem;
    height: 1.05rem;
    transition: transform 0.25s ease;
  }

  .about-cta:hover {
    background: var(--color-gold);
    box-shadow: var(--shadow-gold-halo);
  }

  .about-cta:hover svg {
    transform: translateX(3px);
  }

  .about-cta:focus-visible {
    outline: none;
    box-shadow: var(--shadow-gold-halo);
  }
</style>
