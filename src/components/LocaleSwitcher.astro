---
import { switchLocale } from '../lib/routing';
import { LOCALES, type Locale } from '../lib/i18n';

export interface Props {
  currentLocale: Locale;
  pathname: string;
  variant?: 'header' | 'menu';
}

const { currentLocale, pathname, variant = 'header' } = Astro.props;

type LangOption = {
  locale: Locale;
  label: string;
  flag: string;
  href: string;
};

const flagSvg = (code: string) =>
  `https://hatscripts.github.io/circle-flags/flags/${code}.svg`;

const labels: Record<Locale, { label: string; flag: string }> = {
  en: { label: 'English', flag: 'gb' },
  el: { label: 'Ελληνικά', flag: 'gr' },
  de: { label: 'Deutsch', flag: 'de' },
  fr: { label: 'Français', flag: 'fr' },
  it: { label: 'Italiano', flag: 'it' },
};

const options: LangOption[] = LOCALES.map((locale) => ({
  locale,
  label: labels[locale].label,
  flag: labels[locale].flag,
  href: switchLocale(pathname, currentLocale, locale),
}));

const active = options.find((opt) => opt.locale === currentLocale) ?? options[0];
const uid = `locale-${Math.random().toString(36).slice(2, 9)}`;
---

{variant === 'menu' ? (
  <div class="locale-flags-menu" role="group" aria-label="Language">
    {options.map((opt) => (
      <a
        href={opt.href}
        class="locale-flag-btn"
        data-active={opt.locale === currentLocale ? 'true' : 'false'}
        aria-label={opt.label}
        title={opt.label}
      >
        <img
          src={flagSvg(opt.flag)}
          alt=""
          width="36"
          height="36"
          class="locale-flag-svg"
          loading="lazy"
          decoding="async"
        />
      </a>
    ))}
  </div>
) : (
  <div class="locale-dropdown" data-locale-root={uid}>
    <button
      type="button"
      class="locale-trigger"
      aria-haspopup="listbox"
      aria-expanded="false"
      aria-controls={`${uid}-list`}
      aria-label={`Language: ${active.label}`}
      data-locale-trigger
    >
      <img
        src={flagSvg(active.flag)}
        alt=""
        width="28"
        height="28"
        class="locale-flag-svg locale-flag-svg--trigger"
        loading="lazy"
        decoding="async"
      />
      <svg viewBox="0 0 12 12" class="locale-chevron" aria-hidden="true">
        <path d="M2.5 4.5 6 8 9.5 4.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <ul id={`${uid}-list`} class="locale-panel" role="listbox" aria-label="Language" data-locale-panel hidden>
      {options.map((opt) => (
        <li>
          <a
            href={opt.href}
            class="locale-panel-link"
            role="option"
            aria-selected={opt.locale === currentLocale ? 'true' : 'false'}
            data-active={opt.locale === currentLocale ? 'true' : 'false'}
          >
            <img
              src={flagSvg(opt.flag)}
              alt=""
              width="24"
              height="24"
              class="locale-flag-svg locale-flag-svg--sm"
              loading="lazy"
              decoding="async"
            />
            <span>{opt.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .locale-flag-svg {
    display: block;
    width: 2.25rem;
    height: 2.25rem;
    flex-shrink: 0;
  }

  .locale-flag-svg--trigger {
    width: 1.75rem;
    height: 1.75rem;
  }

  .locale-flag-svg--sm {
    width: 1.5rem;
    height: 1.5rem;
  }

  .locale-flags-menu {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
  }

  .locale-flag-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 2px solid transparent;
    border-radius: 9999px;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .locale-flag-btn:hover {
    transform: translateY(-1px);
    border-color: rgba(201, 168, 76, 0.55);
  }

  .locale-flag-btn[data-active='true'] {
    border-color: var(--color-gold);
  }

  .locale-dropdown {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .locale-trigger {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }

  .locale-trigger:focus-visible {
    outline: 2px solid rgba(201, 168, 76, 0.45);
    outline-offset: 4px;
    border-radius: 9999px;
  }

  .locale-chevron {
    width: 0.65rem;
    height: 0.65rem;
    flex-shrink: 0;
    opacity: 0.85;
    transition: transform 0.2s ease;
  }

  .locale-dropdown[data-open='true'] .locale-chevron {
    transform: rotate(180deg);
  }

  .locale-panel {
    position: absolute;
    top: calc(100% + 0.65rem);
    right: 0;
    z-index: 60;
    min-width: 12.5rem;
    margin: 0;
    padding: 0.4rem 0;
    list-style: none;
    border: 1px solid rgba(10, 10, 10, 0.08);
    border-radius: 0.65rem;
    background: #ffffff;
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.14);
  }

  .locale-panel-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.9rem;
    font-size: 0.9375rem;
    line-height: 1.2;
    color: #0a0a0a;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s ease;
  }

  .locale-panel-link:hover {
    background: rgba(10, 10, 10, 0.04);
  }

  .locale-panel-link[data-active='true'] {
    color: var(--color-gold);
    font-weight: 600;
  }
</style>

<script>
  function initLocaleDropdowns() {
    document.querySelectorAll<HTMLElement>('[data-locale-root]').forEach((root) => {
      if (root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const trigger = root.querySelector<HTMLButtonElement>('[data-locale-trigger]');
      const panel = root.querySelector<HTMLElement>('[data-locale-panel]');
      if (!trigger || !panel) return;

      const close = () => {
        root.dataset.open = 'false';
        trigger.setAttribute('aria-expanded', 'false');
        panel.hidden = true;
      };

      const open = () => {
        document.querySelectorAll<HTMLElement>('[data-locale-root][data-open="true"]').forEach((other) => {
          if (other === root) return;
          other.dataset.open = 'false';
          other.querySelector('[data-locale-trigger]')?.setAttribute('aria-expanded', 'false');
          const otherPanel = other.querySelector<HTMLElement>('[data-locale-panel]');
          if (otherPanel) otherPanel.hidden = true;
        });
        root.dataset.open = 'true';
        trigger.setAttribute('aria-expanded', 'true');
        panel.hidden = false;
      };

      trigger.addEventListener('click', (event) => {
        event.stopPropagation();
        if (root.dataset.open === 'true') close();
        else open();
      });

      document.addEventListener('click', (event) => {
        if (!root.contains(event.target as Node)) close();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') close();
      });
    });
  }

  initLocaleDropdowns();
  document.addEventListener('astro:page-load', initLocaleDropdowns);
</script>
