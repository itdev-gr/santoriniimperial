---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import FleetVehicles from '../components/FleetVehicles.astro';
import { createT } from '../lib/i18n';
import en from '../content/i18n/en.json';
import gr from '../content/i18n/gr.json';

const t = createT('en', { en, gr });
const vehicles = en.fleet.vehicles;
const images = ['/images/fleet/e-class.png', '/images/fleet/v-class.png', '/images/fleet/sprinter-12.png', '/images/fleet/sprinter-20.png'];
---
<BaseLayout title={t('pages.fleet_title')} description={t('pages.fleet_description')} locale="en" pathname="/fleet/">
  <Header slot="header" locale="en" pathname="/fleet/" />
  <Hero image="/images/hero/hero-fleet.jpg" headline={t('fleet.hero.headline')} minHeight="70vh" />
  <FleetVehicles locale="en" vehicles={vehicles} images={images} contactHref="/contact/" />
  <Footer slot="footer" locale="en" />
</BaseLayout>
