---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import FleetVehicles from '../../components/FleetVehicles.astro';
import { createT } from '../../lib/i18n';
import en from '../../content/i18n/en.json';
import gr from '../../content/i18n/gr.json';

const t = createT('el', { en, gr });
const vehicles = gr.fleet.vehicles;
const images = ['/images/gallery/09.jpg', '/images/gallery/02.jpg', '/images/gallery/15.jpg', '/images/gallery/14.jpg'];
---
<BaseLayout title={t('pages.fleet_title')} description={t('pages.fleet_description')} locale="el" pathname="/el/fleet/">
  <Header slot="header" locale="el" pathname="/el/fleet/" />
  <Hero image="/images/hero/hero-fleet.jpg" headline={t('fleet.hero.headline')} minHeight="70vh" />
  <FleetVehicles locale="el" vehicles={vehicles} images={images} contactHref="/el/contact/" />
  <Footer slot="footer" locale="el" />
</BaseLayout>
