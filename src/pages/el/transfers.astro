---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import TransfersServices from '../../components/TransfersServices.astro';
import HomeFaq from '../../components/HomeFaq.astro';
import { createT } from '../../lib/i18n';
import en from '../../content/i18n/en.json';
import gr from '../../content/i18n/gr.json';

const t = createT('el', { en, gr });
const faq = gr.transfers.faq;
---
<BaseLayout title={t('pages.transfers_title')} description={t('pages.transfers_description')} locale="el" pathname="/el/transfers/">
  <Header slot="header" locale="el" pathname="/el/transfers/" />
  <Hero image="/images/hero/hero-transfers.jpg" headlineLine1={t('transfers.hero.headline_line1')} headlineLine2={t('transfers.hero.headline_line2')} minHeight="70vh" />
  <TransfersServices locale="el" />
  <HomeFaq heading={faq.heading} items={faq.items} />
  <Footer slot="footer" locale="el" />
</BaseLayout>
