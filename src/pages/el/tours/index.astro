---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Hero from '../../../components/Hero.astro';
import TourCard from '../../../components/TourCard.astro';
import CtaBand from '../../../components/CtaBand.astro';
import { getCollection } from 'astro:content';

const tours = (await getCollection('tours', (e) => e.data.locale === 'el')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Εμπειρίες — Santorini Imperial" locale="el" pathname="/el/tours/">
  <Header slot="header" locale="el" pathname="/el/tours/" />
  <Hero
    image="/images/hero/hero-tours.jpg"
    kicker="ΕΠΙΛΕΓΜΕΝΕΣ ΕΜΠΕΙΡΙΕΣ"
    headline="Τέσσερις τρόποι να γνωρίσεις το νησί"
    sub="Κάθε εμπειρία είναι ιδιωτική ή ημι-ιδιωτική, με όχημα Mercedes-Benz και εξουσιοδοτημένο ξεναγό όπου χρειάζεται."
    ctaPrimary={{ label: 'Σχεδίασε τη μέρα σου', href: '/el/contact/' }}
    minHeight="70vh"
  />
  <section class="bg-white py-section">
    <div class="container-page grid gap-6 md:grid-cols-2">
      {tours.map(tt => (
        <TourCard
          href={`/el/tours/${tt.data.slug}/`}
          image={tt.data.hero_image}
          title={tt.data.title}
          duration={`${tt.data.duration_hours} ώρες · ${tt.data.format}`}
          summary={(tt.body ?? '').split('\n')[0] ?? ''}
          priceFrom={tt.data.price_from_eur ? `Από €${tt.data.price_from_eur}` : 'Κατόπιν ζήτησης'}
        />
      ))}
    </div>
  </section>
  <CtaBand headline="Σχεδίασε τη μέρα σου, από την αρχή ως το τέλος." cta={{ label: 'Ξεκίνα τον σχεδιασμό', href: '/el/contact/' }} />
  <Footer slot="footer" locale="el" />
</BaseLayout>
