---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import GalleryGrid from '../../components/GalleryGrid.astro';
import CtaBand from '../../components/CtaBand.astro';
import { galleryImages } from '../../lib/gallery';

const images = galleryImages();
---
<BaseLayout title="Συλλογή — Μεταφορές & Περιηγήσεις Σαντορίνη | Santorini Imperial" description="Δείτε φωτογραφίες από τον στόλο Mercedes-Benz της Santorini Imperial, θέα στην καλντέρα, περιηγήσεις κρασιού και τα ομορφότερα σημεία της Σαντορίνης." locale="el" pathname="/el/gallery/">
  <Header slot="header" locale="el" pathname="/el/gallery/" />
  <Hero image="/images/hero/hero-gallery.jpg" kicker="Η ΔΟΥΛΕΙΑ ΜΑΣ" headline="Το νησί, μέσα απ' τον φακό μας" sub="Μια συνεχής συλλογή από εμπειρίες, στόλο και στιγμές της Σαντορίνης που σταθήκαμε τυχεροί να ζήσουμε."
    ctaPrimary={{ label: 'Σχεδίασε μια μέρα μαζί μας', href: '/el/contact/' }} minHeight="60vh" />
  <section class="bg-warm py-section">
    <div class="container-page">
      {images.length > 0
        ? <GalleryGrid images={images} />
        : <p class="text-center text-ink/60">Οι εικόνες φορτώνονται από <code>/public/images/gallery/</code>.</p>}
    </div>
  </section>
  <CtaBand headline="Φτιάξε το δικό σου άλμπουμ Σαντορίνης." cta={{ label: 'Κλείσε μια εμπειρία', href: '/el/tours/' }} />
  <Footer slot="footer" locale="el" />
</BaseLayout>
