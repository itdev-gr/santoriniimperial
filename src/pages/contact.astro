---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import BookingForm from '../components/BookingForm.astro';
import { createT } from '../lib/i18n';
import en from '../content/i18n/en.json';
import gr from '../content/i18n/gr.json';
const t = createT('en', { en, gr });
---
<BaseLayout title="Contact — Santorini Imperial" locale="en" pathname="/contact/">
  <Header slot="header" locale="en" pathname="/contact/" />
  <Hero image="/images/hero/hero-contact.jpg" kicker={t('contact.hero.kicker')} headline={t('contact.hero.headline')} sub={t('contact.hero.sub')}
    ctaPrimary={{ label: 'Call Now', href: 'tel:+306940355016' }}
    ctaSecondary={{ label: 'WhatsApp', href: 'https://wa.me/306940355016' }}
    minHeight="60vh" />

  <section class="bg-white py-section">
    <div class="container-page grid gap-12 md:grid-cols-[3fr_2fr]">
      <div>
        <div class="kicker">BOOKING ENQUIRY</div>
        <h2 class="font-display text-display-lg mt-3">Tell us the plan.</h2>
        <p class="mt-4 text-ink/70 max-w-xl">Fill the form. We reply in under an hour during daylight, within four hours overnight.</p>
        <div class="mt-10"><BookingForm /></div>
      </div>
      <aside class="space-y-8">
        <div>
          <div class="kicker">{t('contact.channels.phone')}</div>
          <ul class="mt-3 space-y-1 text-ink/80">
            <li><a href="tel:+306940355016" class="hover:text-gold">+30 6940 355016</a></li>
            <li><a href="https://wa.me/306940355016" class="hover:text-gold">WhatsApp</a></li>
            <li>Viber · WeChat (same number)</li>
          </ul>
        </div>
        <div>
          <div class="kicker">{t('contact.channels.email')}</div>
          <ul class="mt-3 space-y-1 text-ink/80">
            <li><a href="mailto:imperialsantorini@gmail.com" class="hover:text-gold">imperialsantorini@gmail.com</a></li>
          </ul>
        </div>
        <div>
          <div class="kicker">{t('contact.channels.socials')}</div>
          <div class="mt-3 flex items-center gap-3">
            <a href="https://instagram.com/santorini_imperial" target="_blank" rel="noopener" aria-label="Instagram — @santorini_imperial"
               class="inline-flex items-center justify-center h-10 w-10 rounded-full border border-ink/15 text-ink/70 hover:border-gold hover:text-gold transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </a>
            <a href="https://wa.me/306940355016" target="_blank" rel="noopener" aria-label="WhatsApp — +30 6940 355016"
               class="inline-flex items-center justify-center h-10 w-10 rounded-full border border-ink/15 text-ink/70 hover:border-gold hover:text-gold transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.83 9.83 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.82 11.82 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413"/>
              </svg>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="bg-warm py-section">
    <div class="container-page">
      <div class="kicker">FIND US</div>
      <h2 class="font-display text-display-lg mt-3">Based on the island.</h2>
      <div class="mt-8 aspect-[16/9] rounded-card overflow-hidden shadow-card">
        <iframe
          src="https://maps.google.com/maps?cid=10485640130576047174&output=embed"
          width="100%" height="100%" style="border:0"
          loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          title="Santorini Imperial — Google Maps location"
          allowfullscreen></iframe>
      </div>
      <p class="mt-4 text-sm text-ink/60">
        <a href="https://www.google.com/maps?cid=10485640130576047174" target="_blank" rel="noopener" class="hover:text-gold">Open in Google Maps →</a>
      </p>
    </div>
  </section>

  <Footer slot="footer" locale="en" />
</BaseLayout>
