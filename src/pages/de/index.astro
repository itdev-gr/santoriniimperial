---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import AboutStory from '../../components/AboutStory.astro';
import KickerHeading from '../../components/KickerHeading.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import TourCard from '../../components/TourCard.astro';
import TestimonialsCarousel from '../../components/TestimonialsCarousel.astro';
import HomeFaq from '../../components/HomeFaq.astro';
import ServiceShowcaseCard from '../../components/ServiceShowcaseCard.astro';
import { createT, localePath, bundleForLocale } from '../../lib/i18n';
const locale = 'de' as const;
const t = createT(locale);
const lp = (p: string) => localePath(locale, p);
const bundle = bundleForLocale(locale) as {
  home: {
    services: { items: { title: string; tag: string; body: string; price: string; href: string }[] };
    why: { items: { title: string; body: string }[] };
    tour_cards: { slug: string; title: string; duration: string; summary: string }[];
    testimonials_list: { quote: string; name: string; trip: string }[];
    about_teaser: { stats: { value: string; label: string }[] };
    faq: { kicker: string; heading: string; items: { q: string; a: string }[] };
  };
};

const icons = {
  price: `<svg viewBox='0 0 24 24' fill='none' stroke='#C9A84C' stroke-width='2' class='h-6 w-6'><rect x='3' y='5' width='18' height='14' rx='2'/><path d='M3 10h18'/></svg>`,
  clock: `<svg viewBox='0 0 24 24' fill='none' stroke='#C9A84C' stroke-width='2' class='h-6 w-6'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 2'/></svg>`,
  shield: `<svg viewBox='0 0 24 24' fill='none' stroke='#C9A84C' stroke-width='2' class='h-6 w-6'><path d='M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z'/><path d='M9 12l2 2 4-4'/></svg>`,
  card: `<svg viewBox='0 0 24 24' fill='none' stroke='#C9A84C' stroke-width='2' class='h-6 w-6'><rect x='2' y='5' width='20' height='14' rx='2'/><path d='M2 10h20'/></svg>`,
};
const serviceImages = [
  '/images/hero/hero-transfers.jpg',
  '/images/hero/hero-tours.jpg',
  '/images/gallery/09.jpg',
];
const serviceItems = bundle.home.services.items;
const whyItems = bundle.home.why.items;

const tours = bundle.home.tour_cards.map((tt) => ({
  href: lp(`/tours/${tt.slug}/`),
  image: tt.slug === 'wine-experience' || tt.slug === 'full-day' ? '/images/tours/wine.jpg' : tt.slug === 'sightseeing' ? '/images/tours/sightseeing.jpg' : '/images/tours/photo-tour.jpg',
  title: tt.title,
  duration: tt.duration,
  summary: tt.summary,
  priceFrom: null,
}));

const googleReviewsUrl = 'https://www.google.com/maps/place/Santorini+Imperial+Transfers+and+Tours/@36.4173151,25.4315919,17z/data=!3m1!4b1!4m6!3m5!1s0x1499cd6393a20375:0x91847a24b990dc46!8m2!3d36.4173151!4d25.4341668!16s%2Fg%2F11srs9yylz?entry=ttu';

const testimonials = bundle.home.testimonials_list;
const faq = bundle.home.faq;
const aboutStory = (bundleForLocale(locale) as any).about.story;
---
<BaseLayout title={t('meta.home_title')} description={t('meta.home_description')} locale={locale} pathname="/de/">
  <Header slot="header" locale={locale} pathname="/de/" />

  <Hero
    image="/images/hero/hero-home.jpg"
    headline={t('home.hero.headline')}
    sub={t('home.hero.sub')}
  />

  <section class="bg-white py-section">
    <div class="container-page">
      <KickerHeading heading={t('home.services.heading')} />
      <p class="mx-auto mt-4 max-w-2xl text-center text-ink/70">{t('home.services.sub')}</p>
      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {serviceItems.map((item, i) => (
          <ServiceShowcaseCard
            href={lp(item.href)}
            image={serviceImages[i]}
            tag={item.tag}
            title={item.title}
            body={item.body}
            priceLabel={item.price}
            ctaLabel={t('home.services.cta')}
          />
        ))}
      </div>
    </div>
  </section>

  <AboutStory
      heading={aboutStory.heading}
      paragraphs={aboutStory.paragraphs}
      image="/images/gallery/08.jpg"
      ctaLabel={t('home.about_teaser.cta')}
      ctaHref={lp('/about/')}
    />

  <section class="bg-white py-section">
    <div class="container-page">
      <KickerHeading heading={t('home.why.kicker')} />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <FeatureCard icon={icons.price} title={whyItems[0].title} body={whyItems[0].body} />
        <FeatureCard icon={icons.clock} title={whyItems[1].title} body={whyItems[1].body} />
        <FeatureCard icon={icons.shield} title={whyItems[2].title} body={whyItems[2].body} />
        <FeatureCard icon={icons.card} title={whyItems[3].title} body={whyItems[3].body} />
      </div>
    </div>
  </section>

  <section class="bg-warm py-section">
    <div class="container-page">
      <div class="text-center">
        <h2 class="font-display text-display-lg font-bold leading-[0.95]">{t('home.tours.heading')}</h2>
      </div>
      <div class="mt-12 grid gap-8 sm:grid-cols-2">
        {tours.map(tt => <TourCard href={tt.href} image={tt.image} title={tt.title} duration={tt.duration} summary={tt.summary} priceFrom={tt.priceFrom} ctaLabel={t('home.tours.card_cta')} privateLabel={t('home.tours.private_label')} />)}
      </div>
      <div class="mt-12 text-center"><a href={lp('/tours/')} class="btn-primary">{t('home.tours.cta')} <span aria-hidden="true">→</span></a></div>
    </div>
  </section>

  <TestimonialsCarousel
    heading={t('home.testimonials.heading')}
    testimonials={testimonials}
    googleLabel={t('home.testimonials.google_reviews')}
    googleUrl={googleReviewsUrl}
  />

  <HomeFaq heading={faq.heading} items={faq.items} />

  <Footer slot="footer" locale={locale} />
</BaseLayout>
