---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AboutSplit from '../../components/AboutSplit.astro';
import { createT, bundleForLocale } from '../../lib/i18n';

const locale = 'de' as const;
const t = createT(locale);
const story = (bundleForLocale(locale) as any).about.story;
---
<BaseLayout title={t('pages.about_title')} description={t('pages.about_description')} locale={locale} pathname="/de/about/">
  <Header slot="header" locale={locale} pathname="/de/about/" solid />
  <AboutSplit
    heading={story.heading}
    paragraphs={story.paragraphs}
    image="/images/gallery/15.jpg"
    imageAlt="Mercedes-Benz Van von Santorini Imperial bei Sonnenuntergang"
  />
  <Footer slot="footer" locale={locale} />
</BaseLayout>
