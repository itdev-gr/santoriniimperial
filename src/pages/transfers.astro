---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import TransfersServices from '../components/TransfersServices.astro';
import { createT } from '../lib/i18n';
import en from '../content/i18n/en.json';
import gr from '../content/i18n/gr.json';

const t = createT('en', { en, gr });
---
<BaseLayout title={t('pages.transfers_title')} description={t('pages.transfers_description')} locale="en" pathname="/transfers/">
  <Header slot="header" locale="en" pathname="/transfers/" />
  <Hero image="/images/hero/hero-transfers.jpg" headlineLine1={t('transfers.hero.headline_line1')} headlineLine2={t('transfers.hero.headline_line2')} sub={t('transfers.hero.sub')} minHeight="70vh" />
  <TransfersServices locale="en" />
  <Footer slot="footer" locale="en" />
</BaseLayout>
