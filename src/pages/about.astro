---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AboutSplit from '../components/AboutSplit.astro';
import { createT } from '../lib/i18n';
import en from '../content/i18n/en.json';
import gr from '../content/i18n/gr.json';
const t = createT('en', { en, gr });
const story = en.about.story;
---
<BaseLayout title={t('pages.about_title')} description={t('pages.about_description')} locale="en" pathname="/about/">
  <Header slot="header" locale="en" pathname="/about/" solid />
  <AboutSplit
    heading={story.heading}
    paragraphs={story.paragraphs}
    image="/images/gallery/15.jpg"
    imageAlt="Santorini Imperial Mercedes-Benz van at sunset"
  />
  <Footer slot="footer" locale="en" />
</BaseLayout>
