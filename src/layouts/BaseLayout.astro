---
import '../styles/global.css';
import WhatsAppFab from '../components/WhatsAppFab.astro';
import { hreflangAlternates, absoluteUrl } from '../lib/seo';
import type { Locale } from '../lib/i18n';
import { createT, HTML_LANG, OG_LOCALE, LOCALES } from '../lib/i18n';

export interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  image?: string;
  pathname?: string;
}
const {
  title,
  description,
  locale = 'en',
  image = '/images/hero/hero-home.jpg',
  pathname = Astro.url.pathname,
} = Astro.props;

const t = createT(locale);
const metaDescription = description ?? t('meta.default_description');

const htmlLang = HTML_LANG[locale];
const site = Astro.site?.href ?? 'https://www.imperialsantorini.com';
const alternates = hreflangAlternates(site, pathname, locale);
const ogImage = image.startsWith('http') ? image : absoluteUrl(site, image);
const ogAlternates = LOCALES.filter((loc) => loc !== locale).map((loc) => OG_LOCALE[loc]);
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={alternates.canonical} />
    {LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc} href={alternates.alternates[loc]} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates.xDefault} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={alternates.canonical} />
    <meta property="og:locale" content={OG_LOCALE[locale]} />
    {ogAlternates.map((alt) => (
      <meta property="og:locale:alternate" content={alt} />
    ))}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8ZDSPWZNKP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-8ZDSPWZNKP');
      gtag('config', 'AW-17444343036');

      // Google Ads conversion helper — delay navigation until the event is sent.
      function gtagSendEvent(url) {
        var callback = function () {
          if (typeof url === 'string') {
            window.location = url;
          }
        };
        gtag('event', 'conversion_event_outbound_click', {
          'event_callback': callback,
          'event_timeout': 2000,
        });
        return false;
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot name="header" />
    <main class="flex-1"><slot /></main>
    <slot name="footer" />
    <WhatsAppFab />
    <script>
      import('../lib/animations').then((m) => m.initAllAnimations?.());
    </script>
    <script is:inline>
      // Fire the Google Ads conversion event on key actions (call, email, WhatsApp/Viber, booking).
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
        if (!a) return;
        var href = a.getAttribute('href') || '';
        var isConversion =
          /^tel:|^mailto:|wa\.me|api\.whatsapp\.com|whatsapp:\/\/|viber:\/\//i.test(href) ||
          /\/book\/?($|[?#])/.test(href);
        if (!isConversion || typeof gtag !== 'function') return;

        var newTab = a.target === '_blank' || e.metaKey || e.ctrlKey || e.shiftKey;
        if (newTab) {
          gtag('event', 'conversion_event_outbound_click');
          return;
        }
        e.preventDefault();
        gtagSendEvent(href);
      });
    </script>
  </body>
</html>
